<?xml version="1.0" encoding="UTF-8"?>
<manifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/Framework/App/Manifest/Schema/manifest-2.0.xsd">
    <meta>
        <name>ShopwareStoreTracker</name>
        <label>Shopware Store Tracker</label>
        <description>An App which stores data about physical store locations in real time</description>
        <author>YourNameHere</author>
        <copyright>(c) 2024 YourNameHere</copyright>
        <version>1.0.4</version>
        <icon>[]</icon>
        <license>MIT</license>
    </meta>
    <setup>
        <registrationUrl>http://localhost:8001/app/lifecycle/register</registrationUrl>
        <secret>[SuperSecretString]</secret>
    </setup>
    <webhooks>
        <webhook name="appActivated" url="http://localhost:8001/app/lifecycle/activate" event="app.activated"/>
        <webhook name="appDeactivated" url="http://localhost:8001/app/lifecycle/deactivate" event="app.deactivated"/>
        <webhook name="appDeleted" url="http://localhost:8001/app/lifecycle/delete" event="app.deleted"/>
    </webhooks>
    <permissions>
        <read>ce_physical_shop</read>
        <create>ce_physical_shop</create>
        <update>ce_physical_shop</update>
        <delete>ce_physical_shop</delete>
    </permissions>
</manifest>
